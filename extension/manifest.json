{
  "manifest_version": 3,
  "name": "Alfaleus — Competitor Tracker",
  "version": "1.0.0",
  "description": "Add the current page to your Alfaleus competitor tracker.",
  "permissions": ["activeTab", "storage", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_badge_background_color": "#1db954"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "settings.html"
}
